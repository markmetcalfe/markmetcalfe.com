{
  "name": "markmetcalfe.com",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev:api": "npm --prefix ../api run dev & API_LOCAL=1 nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "typecheck": "nuxt typecheck && tsc --noEmit -p ../api/tsconfig.json",
    "postinstall": "nuxt prepare",
    "test": "npx playwright test",
    "chromatic": "chromatic --playwright --exit-zero-on-changes",
    "lint": "oxlint . && oxfmt --check .",
    "lint:fix": "oxlint . --fix && oxfmt .",
    "prepare": "cd .. && web/node_modules/.bin/husky"
  },
  "dependencies": {
    "@markmetcalfe/resume": "^1.0.0",
    "@nuxt/fonts": "0.14.0",
    "@nuxt/icon": "2.2.3",
    "@nuxt/image": "2.0.0",
    "@nuxt/test-utils": "4.0.3",
    "@pinia/nuxt": "0.11.3",
    "bad-words": "^4.0.0",
    "color-convert": "^3.0.1",
    "hex-color-to-color-name": "^2.0.0",
    "is-mobile": "^5.0.0",
    "nuxt": "^4.0.0",
    "pinia": "^3.0.1",
    "react-device-detect": "^2.2.3",
    "three": "^0.184.0",
    "tone": "^15.0.4",
    "vue": "^3.5.13",
    "vue-router": "^5.0.0"
  },
  "devDependencies": {
    "@chromatic-com/playwright": "^0.12.0",
    "@iconify-json/bx": "^1.2.2",
    "@iconify-json/fad": "^1.2.1",
    "@iconify-json/mdi": "^1.2.2",
    "@iconify-json/simple-icons": "^1.2.2",
    "@playwright/test": "^1.52.0",
    "@types/spotify-api": "^0.0.26",
    "@types/three": "^0.184.0",
    "chromatic": "^17.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "sass": "^1.86.0",
    "stylelint": "^16.16.0",
    "stylelint-config-recommended-scss": "^14.1.0",
    "stylelint-config-recommended-vue": "^1.6.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "typescript": "^5.8.2",
    "vue-tsc": "^3.3.3"
  },
  "lint-staged": {
    "**/*.{js,ts,vue,jsx,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "**/*.{ts,tsx,vue}": "sh -c 'vue-tsc --noEmit -p .nuxt/tsconfig.json'",
    "**/*.vue": "stylelint --fix strict"
  },
  "engines": {
    "node": "22.x.x"
  }
}

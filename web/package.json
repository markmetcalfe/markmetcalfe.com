{
  "name": "markmetcalfe.com-web",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "API_LOCAL=1 nuxt dev --host",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "typecheck": "nuxt typecheck && tsc --noEmit -p ../api/tsconfig.json",
    "postinstall": "nuxt prepare",
    "lint": "oxlint . && oxfmt --check .",
    "lint:fix": "oxlint . --fix && oxfmt ."
  },
  "dependencies": {
    "@markmetcalfe/resume": "^1.0.0",
    "@nuxt/fonts": "0.14.0",
    "@nuxt/icon": "2.2.3",
    "@nuxt/image": "2.0.0",
    "@nuxt/test-utils": "4.0.3",
    "@pinia/nuxt": "0.11.3",
    "color-convert": "^3.0.1",
    "hex-color-to-color-name": "^2.0.0",
    "is-mobile": "^5.0.0",
    "maplibre-gl": "^5.24.0",
    "nuxt": "4.4.6",
    "obscenity": "^0.4.6",
    "pinia": "^3.0.1",
    "react-device-detect": "^2.2.3",
    "three": "^0.185.0",
    "tone": "^15.0.4",
    "vue": "^3.5.13",
    "vue-router": "^5.0.0"
  },
  "devDependencies": {
    "@iconify-json/bx": "^1.2.2",
    "@iconify-json/fad": "^1.2.1",
    "@iconify-json/mdi": "^1.2.2",
    "@iconify-json/simple-icons": "^1.2.2",
    "@maplibre/maplibre-gl-style-spec": "^25.0.0",
    "@types/spotify-api": "^0.0.26",
    "@types/three": "^0.185.0",
    "mapshaper": "^0.7.45",
    "sass": "^1.86.0",
    "stylelint": "^16.16.0",
    "stylelint-config-recommended-scss": "^14.1.0",
    "stylelint-config-recommended-vue": "^1.6.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "vue-tsc": "^3.3.3"
  },
  "lint-staged": {
    "**/*.{js,ts,vue,jsx,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "**/*.{ts,tsx,vue}": "sh -c 'vue-tsc --noEmit -p .nuxt/tsconfig.json'",
    "**/*.vue": "stylelint --fix strict"
  },
  "engines": {
    "node": "22.x.x"
  }
}

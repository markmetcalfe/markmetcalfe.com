{
  "name": "markmetcalfe.com-api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bash dev.sh",
    "deploy:doodle": "wrangler deploy --config doodle/wrangler.jsonc",
    "deploy:network-status": "wrangler deploy --config network-status/wrangler.jsonc",
    "deploy:resume": "wrangler deploy --config resume/wrangler.jsonc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260621.1",
    "eslint": "^10.0.0",
    "lint-staged": "^17.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0",
    "wrangler": "^3.114.17"
  },
  "lint-staged": {
    "**/*.ts": ["eslint --fix", "sh -c 'tsc --noEmit'"]
  }
}

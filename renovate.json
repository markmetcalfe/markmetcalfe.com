{
  "extends": [
    "config:recommended"
  ],
  "minimumReleaseAge": "14 days",
  "packageRules": [
    {
      "description": "Refresh @markmetcalfe lockfile pins every hour instead of waiting for weekly lock file maintenance",
      "matchFileNames": ["web/**"],
      "matchPackageNames": ["@markmetcalfe/*"],
      "matchUpdateTypes": ["lockFileMaintenance"],
      "minimumReleaseAge": null,
      "schedule": ["* * * * *"]
    },
    {
      "description": "Update @markmetcalfe packages every hour",
      "matchFileNames": ["web/**"],
      "matchPackageNames": ["@markmetcalfe/*"],
      "minimumReleaseAge": null,
      "schedule": ["* * * * *"]
    },
    {
      "matchUpdateTypes": [
        "patch"
      ],
      "matchFileNames": ["web/**"],
      "groupName": "web patch dependencies",
      "groupSlug": "web-patch"
    },
    {
      "matchFileNames": ["api/**"],
      "groupName": "api dependencies",
      "groupSlug": "api"
    },
    {
      "matchPackageNames": [
        "node"
      ],
      "enabled": false
    },
    {
      "matchFileNames": ["web/**"],
      "matchPackageNames": ["/oxlint/", "/oxfmt/"],
      "groupName": "web oxlint"
    },
    {
      "matchFileNames": ["web/**"],
      "matchPackageNames": ["nuxt", "/@nuxt/"],
      "groupName": "web nuxt"
    },
    {
      "matchFileNames": ["web/**"],
      "matchPackageNames": ["/^stylelint/"],
      "groupName": "stylelint"
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    },
    {
      "matchFileNames": ["web/**"],
      "matchPackageNames": ["pinia", "/@pinia/"],
      "groupName": "pinia"
    },
    {
      "matchFileNames": ["web/**"],
      "matchPackageNames": ["maplibre-gl", "/@maplibre/"],
      "groupName": "maplibre"
    },
    {
      "matchPackageNames": ["@playwright/test", "chromatic", "@chromatic-com/playwright", "chromaui/action"],
      "groupName": "playwright/chromatic",
      "separateMajorMinor": false
    }
  ],
  "hostRules": [
    {
      "matchHost": "https://npm.pkg.github.com/",
      "hostType": "npm",
      "token": "{{ secrets.NPM_TOKEN }}"
    }
  ],
  "npmrc": "@markmetcalfe:registry=https://npm.pkg.github.com/",
  "lockFileMaintenance": {
    "enabled": true
  },
  "timezone": "Pacific/Auckland",
  "schedule": "* * 1 * *"
}
